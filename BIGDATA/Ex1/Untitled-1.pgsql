{"cells":[{"value":"### 📓 New Notebook: `dbextracaodados`\n\n<div style=\"font-size: 12px; background-color: rgba(52, 152, 219, 0.1); border-left: 3px solid #3498db; padding: 6px 10px; margin-bottom: 15px; border-radius: 3px; color: var(--vscode-editor-foreground);\">\n    <strong>ℹ️ Note:</strong> Write and execute your SQL queries in the cell below.\n</div>","kind":"markdown","language":"markdown"},{"value":"SELECT \n    id_produto,\n    (SELECT count(*) FROM public.produtos) as total_produtos,\n    (SELECT max(preco_produto) FROM public.produtos) as preco_maximo,\n    (SELECT avg(preco_produto) FROM public.produtos) as preco_medio,\n    (SELECT min(preco_produto) FROM public.produtos) as preco_minimo\nFROM public.produtos;\n\n","kind":"sql","language":"sql"}],"metadata":{"connectionId":"1773875787132","databaseName":"dbextracaodados","host":"localhost","port":5433,"username":"postgres","password":"aluno","custom":{"cells":[{"value":"### 📓 New Notebook: `dbextracaodados`\n\n<div style=\"font-size: 12px; background-color: rgba(52, 152, 219, 0.1); border-left: 3px solid #3498db; padding: 6px 10px; margin-bottom: 15px; border-radius: 3px; color: var(--vscode-editor-foreground);\">\n    <strong>ℹ️ Note:</strong> Write and execute your SQL queries in the cell below.\n</div>","kind":"markdown","language":"markdown"},{"value":"SELECT \n    id_produto,\n    (SELECT count(*) FROM public.produtos) as total_produtos,\n    (SELECT max(preco_produto) FROM public.produtos) as preco_maximo,\n    (SELECT avg(preco_produto) FROM public.produtos) as preco_medio,\n    (SELECT min(preco_produto) FROM public.produtos) as preco_minimo\nFROM public.produtos;\n\n","kind":"sql","language":"sql"}],"metadata":{"connectionId":"1773875787132","databaseName":"dbextracaodados","host":"localhost","port":5433,"username":"postgres","password":"aluno","custom":{"cells":[],"metadata":{"connectionId":"1773875787132","databaseName":"dbextracaodados","host":"localhost","port":5433,"username":"postgres"